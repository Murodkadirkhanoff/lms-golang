# Copy to .env and fill JWT_SECRET (at least 32 bytes):
#   openssl rand -hex 32
JWT_SECRET=
JWT_TTL=24h
LMS_ENV=development
LMS_PORT=4000

# Database (either a full DSN or the discrete parts below)
LMS_DB_DSN=postgres://lms:devpassword@localhost:5432/lms?sslmode=disable
# LMS_DB_HOST=localhost
# LMS_DB_PORT=5432
# LMS_DB_USER=lms
# LMS_DB_PASSWORD=devpassword
# LMS_DB_NAME=lms
DB_MAX_OPEN_CONNS=25

CORS_TRUSTED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
PUBLIC_URL=http://localhost:4000
UPLOADS_DIR=uploads

# Empty SMTP host = reset links are logged instead of emailed (dev)
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@lms.chashma.uz

# Per-IP rate limit on auth endpoints
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=2
RATE_LIMIT_BURST=4
