# Go backend base URL (lms.chashma.uz API)
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# When true, services return local mock data instead of calling the API.
NEXT_PUBLIC_USE_MOCK=true

# Public site origin — used for canonical URLs, sitemap, and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://learnhub.uz
