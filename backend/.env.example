# Bu faylni `.env` ga nusxalab, qiymatlarni to'ldiring.
# .env repoga TUSHMAYDI (.gitignore'da).

POSTGRES_USER=lms
POSTGRES_PASSWORD=change_me_in_real_env

# Har servis o'z database'iga ulanadi (db/init/01-create-databases.sql yaratadi)
AUTH_DB_DSN=postgres://lms:change_me_in_real_env@localhost:5432/lms_auth?sslmode=disable
COURSE_DB_DSN=postgres://lms:change_me_in_real_env@localhost:5432/lms_course?sslmode=disable
ENROLLMENT_DB_DSN=postgres://lms:change_me_in_real_env@localhost:5432/lms_enrollment?sslmode=disable

# JWT imzo kaliti — barcha servislarda BIR XIL bo'lishi shart
JWT_SECRET=change_me_long_random_string

# Servislararo /internal/* endpointlar uchun umumiy kalit
INTERNAL_KEY=change_me_another_random_string

# Frontend origin (CORS)
CORS_TRUSTED_ORIGINS=http://localhost:3000

# Servis portlari va manzillari (defaultlar shu qiymatlar)
# AUTH_PORT=4001
# COURSE_PORT=4002
# ENROLLMENT_PORT=4003
# AUTH_SERVICE_URL=http://localhost:4001
# COURSE_SERVICE_URL=http://localhost:4002
