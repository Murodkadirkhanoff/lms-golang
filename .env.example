# Nusxa oling: cp .env.example .env  — va JWT_SECRET'ni to'ldiring:
#   openssl rand -hex 32
JWT_SECRET=
DB_PASSWORD=devpassword
JWT_TTL=24h
LMS_ENV=development
CORS_TRUSTED_ORIGINS=http://localhost:3000
# Brauzerdan backendga boradigan manzil — build paytida frontend bundle'ga yoziladi
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Ixtiyoriy (compose'da default bor):
# FRONTEND_URL=http://localhost:3000     # parol tiklash havolasi uchun
# PUBLIC_URL=http://localhost:4000       # yuklangan fayl URL'lari uchun
# SMTP_HOST=mailpit                      # bo'sh qoldirilsa email logga yoziladi
# SMTP_PORT=1025
# MAIL_FROM=no-reply@lms.chashma.uz
# RATE_LIMIT_ENABLED=true                # auth endpointlari IP limiti
# RATE_LIMIT_RPS=2
# RATE_LIMIT_BURST=4
# MAX_UPLOAD_SIZE=512MB
